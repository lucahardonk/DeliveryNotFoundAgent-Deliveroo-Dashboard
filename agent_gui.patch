+}
+
+/* ── Layout ─────────────────────────────────────────────────────────── */
+.container {
+    display: flex;
+    gap: 16px;
+    padding: 16px;
+    align-items: flex-start;
+    flex-wrap: wrap;
+}
+
+.panel {
+    background: #161b22;
+    border: 1px solid #30363d;
+    border-radius: 8px;
+    padding: 12px;
+}
+
+.panel h2 {
+    font-size: 13px;
+    margin: 0 0 10px 0;
+    color: #58a6ff;
+    text-transform: uppercase;
+    letter-spacing: 1px;
+}
+
+.global-view {
+    flex: 0 0 auto;
+}
+
+.agent-panels {
+    flex: 1 1 420px;
+    min-width: 320px;
+}
+
+.agent-panel {
+    display: none;
+}
+
+.agent-panel.active {
+    display: block;
+}
+
+.agent-body {
+    display: flex;
+    gap: 16px;
+    flex-wrap: wrap;
+}
+
+.canvas-column {
+    display: flex;
+    flex-direction: column;
+    gap: 12px;
+}
+
+.canvas-wrap h3 {
+    font-size: 11px;
+    margin: 0 0 4px 0;
+    color: #8b949e;
+    text-transform: uppercase;
+}
+
+canvas {
+    border: 1px solid #30363d;
+    background: #0d1117;
+    display: block;
+    max-width: 400px;
+    width: 100%;
+    height: auto;
+    image-rendering: pixelated;
+}
+
+/* ── Stats ──────────────────────────────────────────────────────────── */
+.stats {
+    flex: 1 1 200px;
+    min-width: 200px;
+    font-size: 13px;
+    line-height: 1.8;
+}
+
+.stats .row {
+    display: flex;
+    justify-content: space-between;
+    gap: 12px;
+    border-bottom: 1px solid #21262d;
+    padding: 2px 0;
+}
+
+.stats .key {
+    color: #58a6ff;
+}
+
+.stats .value {
+    color: #c9d1d9;
+    text-align: right;
+    word-break: break-word;
+}
+
+.stats .score {
+    font-size: 26px;
+    font-weight: bold;
+    color: #3fb950;
+}
+
+.stats .penalty {
+    color: #f85149;
+}
+
+.stats .state-badge {
+    display: inline-block;
+    padding: 2px 8px;
+    border-radius: 10px;
+    font-size: 11px;
+    font-weight: bold;
+    background: #21262d;
+    color: #58a6ff;
+}
+
+.parcel-list {
+    list-style: none;
+    margin: 4px 0 0 0;
+    padding: 0;
+    font-size: 11px;
+    color: #8b949e;
+}
+
+.parcel-list li {
+    border-bottom: 1px dotted #21262d;
+    padding: 1px 0;
+}
+
+.empty {
+    color: #8b949e;
+    font-style: italic;
+    padding: 20px;
+}
