HOST="http://localhost:8080/"

# ── Tokens ────────────────────────────────────────────────────────────────
# Spawn ONE agent per token. Use ANY of the three formats below.

# 1) Single agent:
TOKEN=your_token

# 2) Many agents, comma-separated (one agent each):
# TOKENS=token_aaa, token_bbb, token_ccc

# 3) Many agents, numbered:
# TOKEN_1=token_aaa
# TOKEN_2=token_bbb

# ── Agent strategy (optional, default: bt) ──────────────────────────────────
# AGENT_TYPE=bt                 # same strategy for every agent ('bt' or 'bdi')
# AGENT_TYPES=bt,bdi,bt         # one per token, aligned with the token order
# AGENT_TYPE_1=bt               # numbered, matches TOKEN_1 / the 1st token
