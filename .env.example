HOST="http://localhost:8080/"

# Standalone dashboard base URL the agents report their state to.
DASHBOARD_URL="http://localhost:3001"
# Dashboard-side (optional): how long an agent can be silent before the
# dashboard drops it, so only currently-active tokens are shown. Default 5000ms.
# AGENT_TTL_MS=5000

# ── Strategy ────────────────────────────────────────────────────────────────
# One of: bt | bdi | base   (default: bt)
AGENT_TYPE=bt
# Per-agent overrides (optional, aligned with token order):
# AGENT_TYPES=bt, bdi, base
# AGENT_TYPE_1=bt
# AGENT_TYPE_2=bdi

# ── Tokens ────────────────────────────────────────────────────────────────
# Spawn ONE agent per token. Use ANY of the three formats below.

# 1) Single agent:
TOKEN=your_token

# 2) Many agents, comma-separated (one agent each):
# TOKENS=token_aaa, token_bbb, token_ccc

# 3) Many agents, numbered:
# TOKEN_1=token_aaa
# TOKEN_2=token_bbb
