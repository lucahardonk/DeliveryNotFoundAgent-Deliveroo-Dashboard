HOST="http://localhost:8080/"
AGENT_TYPE=bt
DASHBOARD_URL=http://localhost:8001

# Spawn ONE agent per token. Use ANY of the three formats below.

# 1) Single agent:
TOKEN=your_token

# 2) Many agents, comma-separated (one agent each):
# TOKENS=token_aaa, token_bbb, token_ccc

# 3) Many agents, numbered:
# TOKEN_1=token_aaa
# TOKEN_2=token_bbb
